{
  "name": "samos-web",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://samos-web.vercel.app",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:css": "npx tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/output.css",
    "watch:css": "npx tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/output.css --watch",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "vercel-build": "npm run build:css && react-scripts build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "framer-motion": "^10.16.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.11.0",
    "react-router-dom": "^6.16.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.3.3"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}